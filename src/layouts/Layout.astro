---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import { siteConfig } from "@/config/site";
import { theme } from "@/config/theme";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  preview?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title, description = siteConfig.description, preview = false } = Astro.props;

const makeTitle = title
  ? title + siteConfig.titleSeparator + siteConfig.name
  : siteConfig.name;
---

<!doctype html>
<html
  lang="en"
  style={`--background:${theme.background};--foreground:${theme.foreground};--card:${theme.card};--card-foreground:${theme.cardForeground};--popover:${theme.popover};--popover-foreground:${theme.popoverForeground};--primary:${theme.primary};--primary-foreground:${theme.primaryForeground};--secondary:${theme.secondary};--secondary-foreground:${theme.secondaryForeground};--muted:${theme.muted};--muted-foreground:${theme.mutedForeground};--accent:${theme.accent};--accent-foreground:${theme.accentForeground};--border:${theme.border};--input:${theme.input};--ring:${theme.ring};--font-heading:${theme.headingFontStack};--font-body:${theme.bodyFontStack};--banner-headline-size:${theme.bannerHeadlineFontSize};`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- <link rel="preload" as="image" href={src} alt="Hero" /> -->
    <SEO
      title={makeTitle}
      description={description}
      canonical={canonicalURL}
      twitter={{
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: siteConfig.name,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: `${siteConfig.name} homepage preview`,
        },
      }}
    />
  </head>
  <body class="bg-background text-foreground">
    {
      preview && (
        <div class="bg-amber-100 px-4 py-2 text-center text-sm font-medium text-amber-900">
          Preview mode. This page is being viewed through a preview URL.
        </div>
      )
    }
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>

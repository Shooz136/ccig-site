---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import { siteConfig } from "@/config/site";
import { theme } from "@/config/theme";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  pageType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
  preview?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const siteName = siteConfig.name;
const organizationName = siteConfig.organizationName || siteName;

const {
  title,
  description = siteConfig.description,
  image = "/opengraph.jpg",
  pageType = "website",
  publishedTime,
  modifiedTime,
  noindex = false,
  preview = false,
} = Astro.props;

const resolvedImageWithDomain = new URL(image, Astro.site).toString();
const shouldNoIndex = preview || noindex;
const robotsContent = shouldNoIndex ? "noindex, nofollow" : "index, follow";

const makeTitle = title
  ? title + siteConfig.titleSeparator + siteName
  : siteName;

const schemaGraph = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${Astro.site}#organization`,
    name: organizationName,
    url: Astro.site,
    image: resolvedImageWithDomain,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${Astro.site}#website`,
    name: siteName,
    url: Astro.site,
    description: siteConfig.description,
    publisher: {
      "@id": `${Astro.site}#organization`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": pageType === "article" ? "Article" : "WebPage",
    "@id": `${canonicalURL}#page`,
    url: canonicalURL,
    name: makeTitle,
    description,
    image: resolvedImageWithDomain,
    isPartOf: {
      "@id": `${Astro.site}#website`,
    },
    about: {
      "@id": `${Astro.site}#organization`,
    },
    ...(publishedTime ? { datePublished: publishedTime } : {}),
    ...(modifiedTime ? { dateModified: modifiedTime } : {}),
  },
];
---

<!doctype html>
<html
  lang="en"
  style={`--background:${theme.background};--foreground:${theme.foreground};--card:${theme.card};--card-foreground:${theme.cardForeground};--popover:${theme.popover};--popover-foreground:${theme.popoverForeground};--primary:${theme.primary};--primary-foreground:${theme.primaryForeground};--secondary:${theme.secondary};--secondary-foreground:${theme.secondaryForeground};--muted:${theme.muted};--muted-foreground:${theme.mutedForeground};--accent:${theme.accent};--accent-foreground:${theme.accentForeground};--border:${theme.border};--input:${theme.input};--ring:${theme.ring};--font-heading:${theme.headingFontStack};--font-body:${theme.bodyFontStack};--banner-headline-size:${theme.bannerHeadlineFontSize};`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={robotsContent} />
    <meta property="og:site_name" content={siteName} />
    <SEO
      title={makeTitle}
      description={description}
      canonical={canonicalURL}
      noindex={shouldNoIndex}
      nofollow={shouldNoIndex}
      twitter={{
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: pageType,
          title: makeTitle,
          description,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: `${siteName} page preview`,
        },
        article:
          pageType === "article"
            ? {
                publishedTime,
                modifiedTime,
              }
            : undefined,
      }}
    />
    <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>
  <body class="bg-background text-foreground">
    {
      preview && (
        <div class="bg-amber-100 px-4 py-2 text-center text-sm font-medium text-amber-900">
          Preview mode. This page is being viewed through a preview URL.
        </div>
      )
    }
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>

---
import { getCollection, getEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { isValidPreviewRequest } from "@/lib/preview";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");

  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/blog");
}

if (!isValidPreviewRequest(Astro.url)) {
  return new Response("Not found", { status: 404 });
}

const entry = await getEntry("blog", slug);

if (!entry) {
  return new Response("Not found", { status: 404 });
}

const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} Preview`} preview={true}>
  <Container>
    <div class="mx-auto mt-14 max-w-3xl">
      <span class="text-theme-accent uppercase tracking-wider text-sm font-medium">
        {entry.data.category}
      </span>
      <h1
        class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-1 lg:leading-tight">
        {entry.data.title}
      </h1>
      <div class="flex gap-2 mt-3 items-center flex-wrap md:flex-nowrap">
        <span class="text-theme-muted">
          {entry.data.author}
        </span>
        <span class="text-theme-muted">•</span>
        <time
          class="text-theme-muted"
          datetime={entry.data.publishDate.toISOString()}>
          {entry.data.publishDate.toDateString()}
        </time>
        <span class="text-theme-muted hidden md:block">•</span>
        <div class="w-full md:w-auto flex flex-wrap gap-3">
          {
            entry.data.tags.map((tag) => (
              <span class="text-sm text-theme-muted">#{tag}</span>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mx-auto prose prose-lg mt-6 max-w-3xl prose-headings:text-theme prose-p:text-theme prose-li:text-theme prose-strong:text-theme prose-a:text-[var(--theme-accent)] prose-code:text-theme">
      <Content />
    </div>
  </Container>
</Layout>

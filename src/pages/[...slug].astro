---
import { getCollection } from "astro:content";
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
import { normalizePageSlug } from "@/lib/pages";
import PageSections from "@/components/page-builder/page-sections.astro";

export async function getStaticPaths() {
  const pages = (await getCollection("pages", ({ data }) => !data.draft))
    .map((entry) => ({ ...entry, normalizedSlug: normalizePageSlug(entry.slug) }))
    .filter((entry) => entry.normalizedSlug);

  return pages.map((entry) => ({
    params: { slug: entry.normalizedSlug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<Layout title={entry.data.title} description={entry.data.description}>
  <Container>
    <PageSections sections={entry.data.sections} />
  </Container>
</Layout>

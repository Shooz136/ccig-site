---
import { getEntry } from "astro:content";
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
import PageSections from "@/components/page-builder/page-sections.astro";
import { getPagePreviewImage } from "@/lib/pages";

const home = await getEntry("pages", "home");

if (!home) {
  throw new Error('Missing "home" entry in src/content/pages/home.md');
}

const homeImage = getPagePreviewImage(home.data.sections);
---

<Layout title="" description={home.data.description} image={homeImage}>
  <Container>
    <PageSections sections={home.data.sections} />
  </Container>
</Layout>

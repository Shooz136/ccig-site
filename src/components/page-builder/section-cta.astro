---
import ActionButtons from "@/components/page-builder/action-buttons.astro";
import RichText from "@/components/page-builder/rich-text.astro";

const { title, body, buttonLabel, buttonHref, buttonStyle = "inverted" } = Astro.props;
---

<section class="py-12">
  <div class="mx-auto max-w-5xl rounded-3xl bg-primary px-8 py-12 text-center md:px-16">
    <h2 class="text-3xl font-bold tracking-tight text-primary-foreground lg:text-5xl">
      {title}
    </h2>
    <RichText
      content={body}
      class="mx-auto mt-5 max-w-2xl text-[color-mix(in_srgb,var(--primary-foreground)_78%,transparent)] prose-p:text-lg prose-p:leading-relaxed prose-strong:text-primary-foreground prose-a:text-primary-foreground"
    />
    <ActionButtons
      class="mt-8 justify-center"
      buttons={[{ label: buttonLabel, href: buttonHref, style: buttonStyle }]}
    />
  </div>
</section>

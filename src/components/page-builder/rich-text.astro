---
const { content, class: className } = Astro.props;
---

{
  content && (
    <div
      class:list={[
        "prose prose-lg max-w-none prose-headings:text-theme prose-p:text-inherit prose-li:text-inherit prose-strong:text-theme prose-a:text-[var(--theme-accent)] prose-code:text-theme",
        className,
      ]}
      set:html={content}
    />
  )
}

---
const { embedCode, maxWidth = "lg" } = Astro.props;

const widthClasses = {
  md: "max-w-4xl",
  lg: "max-w-5xl",
  full: "max-w-6xl",
};
---

<section class="py-12">
  <div class:list={["mx-auto", widthClasses[maxWidth] ?? widthClasses.lg]}>
    <div class="overflow-hidden rounded-[2rem] border border-border/70 bg-[linear-gradient(180deg,color-mix(in_srgb,var(--secondary)_72%,white),white_40%)] shadow-[0_30px_90px_-54px_rgba(12,40,99,0.28)]">
      <div class="px-8 py-10 md:px-12 md:py-12">
        <div class="embed-shell" set:html={embedCode} />
      </div>
    </div>
  </div>
</section>

<style>
  .embed-shell :global(*) {
    box-sizing: border-box;
    max-width: 100%;
  }

  .embed-shell :global(iframe),
  .embed-shell :global(video),
  .embed-shell :global(form) {
    width: 100%;
  }

  .embed-shell :global(iframe),
  .embed-shell :global(video) {
    min-height: 28rem;
    border: 0;
    border-radius: 1.25rem;
  }
</style>

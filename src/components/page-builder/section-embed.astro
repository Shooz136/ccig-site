---
const { embedCode, maxWidth = "lg" } = Astro.props;

const widthClasses = {
  md: "max-w-3xl",
  lg: "max-w-4xl",
  full: "max-w-6xl",
};
---

<section class="py-12">
  <div class:list={["mx-auto", widthClasses[maxWidth] ?? widthClasses.lg]}>
    <div class="overflow-hidden rounded-[1.75rem] border border-border/55 bg-[color:color-mix(in_srgb,var(--secondary)_38%,white)] shadow-[0_18px_48px_-40px_rgba(12,40,99,0.14)]">
      <div class="px-5 py-5 md:px-6 md:py-6">
        <div class="embed-shell" set:html={embedCode} />
      </div>
    </div>
  </div>
</section>

<style>
  .embed-shell {
    position: relative;
    width: 100%;
    min-height: clamp(32rem, 72vh, 56rem);
    overflow: hidden;
    border-radius: 1.25rem;
  }

  .embed-shell :global(*) {
    box-sizing: border-box;
    max-width: 100%;
  }

  .embed-shell :global(iframe),
  .embed-shell :global(video),
  .embed-shell :global(form) {
    width: 100%;
  }

  .embed-shell :global(iframe),
  .embed-shell :global(video) {
    height: 100%;
    border: 0;
    border-radius: 1.25rem;
  }
</style>

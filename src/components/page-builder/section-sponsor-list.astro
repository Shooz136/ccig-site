---
import RichText from "@/components/page-builder/rich-text.astro";
import SponsorGroups from "@/components/sponsors/sponsor-groups.astro";
import { getPublishedSponsors, groupSponsorsByLevel } from "@/lib/sponsors";

const { title, body, levels = [] } = Astro.props;

const sponsors = await getPublishedSponsors();
const filteredSponsors =
  levels.length > 0
    ? sponsors.filter((sponsor) => levels.includes(sponsor.data.level))
    : sponsors;
const sponsorGroups = groupSponsorsByLevel(filteredSponsors);
---

<section class="py-12">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-3xl">
      <h2 class="text-4xl font-bold tracking-tight text-foreground lg:text-5xl">
        {title}
      </h2>
      {body && <RichText content={body} class="mt-4 text-muted-foreground" />}
    </div>

    <div class="mt-12">
      {
        sponsorGroups.length > 0 ? (
          <SponsorGroups groups={sponsorGroups} />
        ) : (
          <p class="text-muted-foreground">No sponsors match the selected levels yet.</p>
        )
      }
    </div>
  </div>
</section>

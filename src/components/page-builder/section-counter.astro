---
import RichText from "@/components/page-builder/rich-text.astro";
import { siteConfig } from "@/config/site";

const { label = "Cats fixed", heading, body = "" } = Astro.props;
const formattedCount = new Intl.NumberFormat("en-US").format(
  siteConfig.catsFixedCount ?? 0
);
---

<section class="py-12">
  <div class="mx-auto max-w-6xl rounded-[2rem] border border-border bg-background p-6 shadow-[0_26px_70px_-54px_rgba(12,40,99,0.45)] sm:p-8 lg:p-10">
    <div class="grid items-center gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-14">
      <div class="flex flex-col items-center justify-center text-center">
        <div class="relative flex h-44 w-44 items-center justify-center rounded-full bg-primary text-primary-foreground shadow-[0_22px_48px_-30px_rgba(12,40,99,0.65)] ring-8 ring-secondary sm:h-52 sm:w-52 lg:h-56 lg:w-56">
          <div class="absolute inset-3 rounded-full border border-primary-foreground/25"></div>
          <span class="relative text-6xl font-extrabold leading-none tracking-tight sm:text-7xl lg:text-8xl">
            {formattedCount}
          </span>
        </div>
        {
          label && (
            <p class="mt-6 text-sm font-bold uppercase tracking-[0.28em] text-foreground sm:text-base">
              {label}
            </p>
          )
        }
      </div>

      <div class="mx-auto max-w-3xl text-center lg:mx-0 lg:text-left">
        <h2 class="text-4xl font-bold tracking-tight text-foreground lg:text-5xl">
          {heading}
        </h2>
        {
          body && (
            <RichText
              content={body}
              class="mt-6 text-xl leading-relaxed text-muted-foreground prose-ul:mx-auto prose-ul:inline-block prose-ul:text-left prose-li:pl-2 prose-li:marker:text-primary lg:prose-ul:mx-0"
            />
          )
        }
      </div>
    </div>
  </div>
</section>

---
import RichText from "@/components/page-builder/rich-text.astro";
import "swiper/css";
import "swiper/css/navigation";
import "swiper/css/pagination";

const {
  eyebrow = "",
  title,
  body = "",
  slides = [],
  autoplay = false,
  showNavigation = true,
  showPagination = true,
  mobileSlidesPerView = 1.1,
  tabletSlidesPerView = 2,
  desktopSlidesPerView = 3,
  spaceBetween = 24,
  imageAspect = "landscape",
} = Astro.props;

const carouselId = `image-carousel-${Math.random().toString(36).slice(2, 10)}`;
const imageAspectClass =
  imageAspect === "square"
    ? "aspect-square"
    : imageAspect === "portrait"
      ? "aspect-[4/5]"
      : imageAspect === "wide"
        ? "aspect-[16/9]"
        : "aspect-[4/3]";
---

<section class="py-12">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-3xl">
      {
        eyebrow && (
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-accent">
            {eyebrow}
          </p>
        )
      }
      <h2 class="mt-3 text-4xl font-bold tracking-tight text-foreground lg:text-5xl">
        {title}
      </h2>
      {body && <RichText content={body} class="mt-4 text-muted-foreground" />}
    </div>

    <div
      class="relative mt-10 pb-12"
      data-image-carousel={carouselId}
      data-autoplay={autoplay ? "true" : "false"}
      data-show-navigation={showNavigation ? "true" : "false"}
      data-show-pagination={showPagination ? "true" : "false"}
      data-mobile-slides-per-view={String(mobileSlidesPerView)}
      data-tablet-slides-per-view={String(tabletSlidesPerView)}
      data-desktop-slides-per-view={String(desktopSlidesPerView)}
      data-space-between={String(spaceBetween)}
      aria-label={title}>
      <div class="pointer-events-none absolute inset-y-0 left-0 z-10 hidden w-8 bg-[linear-gradient(90deg,color-mix(in_srgb,var(--background)_88%,transparent),transparent_72%)] md:block lg:w-12"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 z-10 hidden w-8 bg-[linear-gradient(270deg,color-mix(in_srgb,var(--background)_88%,transparent),transparent_72%)] md:block lg:w-12"></div>

      <div class="overflow-hidden rounded-[2rem]">
        <div class="swiper">
          <div class="swiper-wrapper">
            {
              slides.map((slide) => (
                <div class="swiper-slide">
                  <figure class="overflow-hidden rounded-[1.65rem] border border-border bg-background shadow-[0_24px_60px_-42px_rgba(15,23,42,0.32)]">
                    <img
                      src={slide.image.src}
                      alt={slide.image.alt}
                      class:list={[imageAspectClass, "w-full object-cover"]}
                      loading="lazy"
                    />
                    {
                      (slide.title || slide.description) && (
                        <figcaption class="bg-background px-5 py-5 text-card-foreground">
                          {slide.title && (
                            <h3 class="text-xl font-semibold leading-tight tracking-tight">
                              {slide.title}
                            </h3>
                          )}
                          {slide.description && (
                            <p class:list={["leading-relaxed text-card-foreground/78", slide.title ? "mt-3" : ""]}>
                              {slide.description}
                            </p>
                          )}
                        </figcaption>
                      )
                    }
                  </figure>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      {
        showPagination && <div class="swiper-pagination image-carousel-pagination"></div>
      }
      {
        showNavigation && (
          <>
            <button
              type="button"
              class="swiper-button-prev image-carousel-button"
              aria-label="Previous slide"></button>
            <button
              type="button"
              class="swiper-button-next image-carousel-button"
              aria-label="Next slide"></button>
          </>
        )
      }
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { A11y, Autoplay, Navigation, Pagination } from "swiper/modules";

  const initImageCarousels = () => {
    document.querySelectorAll("[data-image-carousel]").forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.initialized === "true") {
        return;
      }

      const swiperRoot = root.querySelector(".swiper");

      if (!(swiperRoot instanceof HTMLElement)) {
        return;
      }

      const slideCount = swiperRoot.querySelectorAll(".swiper-slide").length;
      const showNavigation = root.dataset.showNavigation === "true";
      const showPagination = root.dataset.showPagination === "true";
      const mobileSlidesPerView = Number(root.dataset.mobileSlidesPerView || "1.1");
      const tabletSlidesPerView = Number(root.dataset.tabletSlidesPerView || "2");
      const desktopSlidesPerView = Number(root.dataset.desktopSlidesPerView || "3");
      const spaceBetween = Number(root.dataset.spaceBetween || "24");
      root.dataset.initialized = "true";

      new Swiper(swiperRoot, {
        modules: [A11y, Autoplay, Navigation, Pagination],
        loop: slideCount > 1,
        speed: 650,
        grabCursor: slideCount > 1,
        watchOverflow: true,
        slidesPerView: mobileSlidesPerView,
        spaceBetween,
        breakpoints: {
          768: {
            slidesPerView: tabletSlidesPerView,
            spaceBetween,
          },
          1200: {
            slidesPerView: desktopSlidesPerView,
            spaceBetween,
          },
        },
        navigation:
          showNavigation
            ? {
                nextEl: root.querySelector(".swiper-button-next"),
                prevEl: root.querySelector(".swiper-button-prev"),
              }
            : false,
        pagination:
          showPagination
            ? {
                el: root.querySelector(".swiper-pagination"),
                clickable: true,
              }
            : false,
        autoplay:
          root.dataset.autoplay === "true" && slideCount > 1
            ? {
                delay: 4500,
                disableOnInteraction: false,
                pauseOnMouseEnter: true,
              }
            : false,
        a11y: {
          prevSlideMessage: "Previous image",
          nextSlideMessage: "Next image",
          paginationBulletMessage: "Go to image {{index}}",
        },
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initImageCarousels, { once: true });
  } else {
    initImageCarousels();
  }
</script>

<style>
  :global([data-image-carousel] .image-carousel-button) {
    position: absolute;
    top: 50%;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 3rem;
    width: 3rem;
    margin-top: 0;
    padding: 0;
    border-radius: 9999px;
    appearance: none;
    background: color-mix(in srgb, var(--background) 94%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 88%, transparent);
    box-shadow: 0 12px 30px -18px rgba(15, 23, 42, 0.45);
    color: var(--foreground);
    transform: translateY(-50%);
    backdrop-filter: blur(10px);
    cursor: pointer;
    transition:
      background-color 180ms ease,
      color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  :global([data-image-carousel] .image-carousel-button:hover) {
    background: var(--foreground);
    color: var(--background);
    box-shadow: 0 16px 34px -18px rgba(15, 23, 42, 0.55);
  }

  :global([data-image-carousel] .image-carousel-button::after) {
    content: none;
  }

  :global([data-image-carousel] .image-carousel-button .swiper-navigation-icon) {
    width: 0.9rem;
    height: 0.9rem;
    display: block;
  }

  :global([data-image-carousel] .swiper-button-prev .swiper-navigation-icon) {
    transform: rotate(180deg);
  }

  :global([data-image-carousel] .swiper-button-prev) {
    left: 0.85rem;
  }

  :global([data-image-carousel] .swiper-button-next) {
    right: 0.85rem;
  }

  :global([data-image-carousel] .swiper-button-disabled) {
    opacity: 0.35;
    pointer-events: none;
  }

  :global([data-image-carousel] .image-carousel-pagination) {
    position: absolute;
    left: 1.5rem;
    right: 1.5rem;
    bottom: 0 !important;
    width: auto !important;
    display: flex;
    justify-content: center;
    gap: 0.4rem;
  }

  :global([data-image-carousel] .swiper-pagination-bullet) {
    width: 0.7rem;
    height: 0.7rem;
    margin: 0 !important;
    background: color-mix(in srgb, var(--background) 55%, transparent);
    opacity: 1;
  }

  :global([data-image-carousel] .swiper-pagination-bullet-active) {
    background: var(--accent);
  }
  
  @media (max-width: 640px) {
    :global([data-image-carousel] .image-carousel-button) {
      display: none;
    }
  }
</style>

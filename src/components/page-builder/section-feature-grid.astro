---
import RichText from "@/components/page-builder/rich-text.astro";
import { Icon } from "astro-icon/components";

const { title, body, features = [] } = Astro.props;
---

<section class="py-12">
  <div class="mx-auto max-w-5xl">
    <div class="max-w-3xl">
      <h2 class="text-4xl font-bold tracking-tight text-foreground lg:text-5xl">
        {title}
      </h2>
      <RichText content={body} class="mt-4 text-muted-foreground" />
    </div>

    <div class="mt-14 grid gap-12 sm:grid-cols-2 md:grid-cols-3">
      {
        features.map((feature) => (
          <div class="flex items-start gap-4">
            {(feature.stepNumber || feature.icon) && (
              <div class="mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-foreground">
                {feature.stepNumber ? (
                  <span>{feature.stepNumber}</span>
                ) : (
                  <Icon class="h-5 w-5 text-primary-foreground" name={feature.icon} />
                )}
              </div>
            )}
            <div>
              <h3 class="text-lg font-semibold text-foreground">
                {feature.title}
              </h3>
              <p class="mt-2 leading-relaxed text-muted-foreground">
                {feature.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

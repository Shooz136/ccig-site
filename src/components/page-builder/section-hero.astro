---
import ActionButtons from "@/components/page-builder/action-buttons.astro";
import RichText from "@/components/page-builder/rich-text.astro";

const {
  eyebrow,
  headline,
  body,
  align = "center",
  primaryCtaLabel,
  primaryCtaHref,
  primaryCtaStyle = "primary",
  secondaryCtaLabel,
  secondaryCtaHref,
  secondaryCtaStyle = "outline",
} = Astro.props;

const isCentered = align === "center";
---

<section class:list={["mx-auto max-w-5xl py-14", isCentered ? "text-center" : "text-left"]}>
  {eyebrow && (
    <p class="mb-4 text-sm font-semibold uppercase tracking-[0.24em] text-accent">
      {eyebrow}
    </p>
  )}
  <h1 class="text-5xl font-bold tracking-tight text-foreground lg:text-7xl">
    {headline}
  </h1>
  {body && (
    <RichText
      content={body}
      class:list={[
        "mt-6 max-w-3xl text-muted-foreground prose-p:text-xl prose-p:leading-relaxed",
        isCentered && "mx-auto",
      ]}
    />
  )}
  <ActionButtons
    class:list={["mt-8", isCentered ? "justify-center" : "justify-start"]}
    buttons={[
      {
        label: primaryCtaLabel,
        href: primaryCtaHref,
        style: primaryCtaStyle,
        class: "flex items-center justify-center",
      },
      {
        label: secondaryCtaLabel,
        href: secondaryCtaHref,
        style: secondaryCtaStyle,
        class: "flex items-center justify-center",
      },
    ]}
  />
</section>

---
import SectionCta from "@/components/page-builder/section-cta.astro";
import SectionContact from "@/components/page-builder/section-contact.astro";
import SectionFeatureGrid from "@/components/page-builder/section-feature-grid.astro";
import SectionFullWidthBanner from "@/components/page-builder/section-full-width-banner.astro";
import SectionImageCarousel from "@/components/page-builder/section-image-carousel.astro";
import SectionHero from "@/components/page-builder/section-hero.astro";
import SectionInfoCardList from "@/components/page-builder/section-info-card-list.astro";
import SectionImageText from "@/components/page-builder/section-image-text.astro";
import SectionLinkedContentList from "@/components/page-builder/section-linked-content-list.astro";
import SectionLogoCloud from "@/components/page-builder/section-logo-cloud.astro";
import SectionSponsorList from "@/components/page-builder/section-sponsor-list.astro";
import SectionTeamMembers from "@/components/page-builder/section-team-members.astro";
import SectionText from "@/components/page-builder/section-text.astro";

const { sections = [] } = Astro.props;
---

{
  sections.map((section) => {
    if (section.type === "hero") {
      return <SectionHero {...section} />;
    }

    if (section.type === "full_width_banner") {
      return <SectionFullWidthBanner {...section} />;
    }

    if (section.type === "text") {
      return <SectionText {...section} />;
    }

    if (section.type === "image_text") {
      return <SectionImageText {...section} />;
    }

    if (section.type === "image_carousel") {
      return <SectionImageCarousel {...section} />;
    }

    if (section.type === "info_card_list") {
      return <SectionInfoCardList {...section} />;
    }

    if (section.type === "cta") {
      return <SectionCta {...section} />;
    }

    if (section.type === "contact") {
      return <SectionContact {...section} />;
    }

    if (section.type === "feature_grid") {
      return <SectionFeatureGrid {...section} />;
    }

    if (section.type === "logo_cloud") {
      return <SectionLogoCloud {...section} />;
    }

    if (section.type === "linked_content_list") {
      return <SectionLinkedContentList {...section} />;
    }

    if (section.type === "sponsor_list") {
      return <SectionSponsorList {...section} />;
    }

    if (section.type === "team_members") {
      return <SectionTeamMembers {...section} />;
    }

    return null;
  })
}

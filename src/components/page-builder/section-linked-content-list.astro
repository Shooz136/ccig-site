---
import RichText from "@/components/page-builder/rich-text.astro";

const { title, body, items = [] } = Astro.props;
---

<section class="py-12">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-3xl">
      <h2 class="text-4xl font-bold tracking-tight text-foreground lg:text-5xl">
        {title}
      </h2>
      {body && <RichText content={body} class="mt-4 text-muted-foreground" />}
    </div>

    <ul class="mt-12 grid gap-12">
      {
        items.map((item) => (
          <li>
            <a href={item.linkHref} class="group block">
              <div class="grid items-center gap-5 md:grid-cols-[minmax(0,28rem)_minmax(0,1fr)] md:gap-10">
                <div class="overflow-hidden rounded-2xl border border-border shadow-[0_20px_50px_-35px_rgba(15,23,42,0.35)]">
                  <img
                    src={item.image.src}
                    alt={item.image.alt}
                    class="aspect-[4/5] w-full object-cover object-center transition duration-200 group-hover:scale-[1.01] md:max-h-[32rem]"
                    loading="lazy"
                  />
                </div>
                <div>
                  {item.eyebrow && (
                    <span class="text-sm font-medium uppercase tracking-wider text-accent">
                      {item.eyebrow}
                    </span>
                  )}

                  <h3 class="mt-2 text-3xl font-semibold leading-snug tracking-tight text-foreground">
                    {item.title}
                  </h3>

                  {item.description && (
                    <p class="mt-4 leading-relaxed text-muted-foreground">
                      {item.description}
                    </p>
                  )}

                  <span class="mt-5 inline-flex items-center font-semibold text-foreground transition group-hover:text-accent">
                    {item.linkLabel}
                    <span class="ml-2 transition group-hover:translate-x-1">→</span>
                  </span>
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

---
import { getCollection } from "astro:content";
import RichText from "@/components/page-builder/rich-text.astro";

const { eyebrow = "", title, body = "" } = Astro.props;

const teamMembers = await getCollection("team", ({ data }) => !data.draft);
const getFirstName = (name: string) => name.trim().split(/\s+/)[0] || name.trim();

teamMembers.sort((a, b) => {
  const firstNameComparison = getFirstName(a.data.name).localeCompare(getFirstName(b.data.name));

  if (firstNameComparison !== 0) {
    return firstNameComparison;
  }

  return a.data.name.localeCompare(b.data.name);
});

const getAccentSeed = (name: string) => name.trim().toLowerCase().charCodeAt(0) % 3;
---

<section class="py-12">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-3xl">
      {
        eyebrow && (
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-accent">
            {eyebrow}
          </p>
        )
      }
      <h2 class="mt-3 text-4xl font-bold tracking-tight text-foreground lg:text-5xl">
        {title}
      </h2>
      {body && <RichText content={body} class="mt-4 text-lg text-muted-foreground" />}
    </div>

    <div class="mt-12 grid items-start gap-8 md:grid-cols-2 xl:grid-cols-3">
      {
        teamMembers.map((member) => {
          const accentSeed = getAccentSeed(member.data.name);
          const accentClass =
            accentSeed === 0
              ? "bg-[linear-gradient(135deg,color-mix(in_srgb,var(--accent)_72%,white),color-mix(in_srgb,var(--accent)_88%,black))]"
              : accentSeed === 1
                ? "bg-[linear-gradient(135deg,color-mix(in_srgb,var(--primary)_68%,white),color-mix(in_srgb,var(--primary)_84%,black))]"
                : "bg-[linear-gradient(135deg,color-mix(in_srgb,var(--foreground)_16%,white),color-mix(in_srgb,var(--foreground)_62%,white))]";

          return (
            <article class="overflow-hidden rounded-[2rem] border border-border bg-background shadow-[0_30px_80px_-46px_rgba(15,23,42,0.28)] transition-transform duration-200 hover:-translate-y-1">
              <div class:list={["px-5 pb-5 pt-5", accentClass]}>
                <div class="rounded-[1.45rem] border border-white/60 bg-white/18 p-2 backdrop-blur-sm">
                  <img
                    src={member.data.avatar.src}
                    alt={member.data.avatar.alt}
                    class="aspect-[4/3] w-full rounded-[1rem] object-cover"
                    loading="lazy"
                  />
                </div>
              </div>

              <div class="bg-background px-6 pb-7 pt-6">
                <div class="h-1.5 w-16 rounded-full bg-[color-mix(in_srgb,var(--accent)_72%,white)]"></div>
                <h3 class="mt-4 text-[1.95rem] font-semibold leading-tight tracking-tight text-foreground">
                  {member.data.name}
                </h3>
                <p class="mt-4 max-w-[28ch] text-[1rem] leading-8 text-foreground/76">
                  {member.data.biography}
                </p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

---
import { getCollection } from "astro:content";
import RichText from "@/components/page-builder/rich-text.astro";

const { eyebrow = "", title, body = "" } = Astro.props;

const teamMembers = await getCollection("team", ({ data }) => !data.draft);
const getFirstName = (name: string) => name.trim().split(/\s+/)[0] || name.trim();

teamMembers.sort((a, b) => {
  const firstNameComparison = getFirstName(a.data.name).localeCompare(getFirstName(b.data.name));

  if (firstNameComparison !== 0) {
    return firstNameComparison;
  }

  return a.data.name.localeCompare(b.data.name);
});

const getAccentSeed = (name: string) =>
  name
    .trim()
    .toLowerCase()
    .charCodeAt(0) % 3;
---

<section class="py-12">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-3xl">
      {
        eyebrow && (
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-accent">
            {eyebrow}
          </p>
        )
      }
      <h2 class="mt-3 text-4xl font-bold tracking-tight text-foreground lg:text-5xl">
        {title}
      </h2>
      {body && <RichText content={body} class="mt-4 text-lg text-muted-foreground" />}
    </div>

    <div class="mt-12 grid items-start gap-8 md:grid-cols-2 xl:grid-cols-3">
      {
        teamMembers.map((member) => {
          const accentSeed = getAccentSeed(member.data.name);
          const accentClass =
            accentSeed === 0
              ? "bg-[color-mix(in_srgb,var(--accent)_78%,white)]"
              : accentSeed === 1
                ? "bg-[color-mix(in_srgb,var(--primary)_78%,white)]"
                : "bg-[color-mix(in_srgb,var(--foreground)_72%,white)]";

          return (
            <article class="overflow-hidden rounded-[2rem] border border-border bg-card shadow-[0_28px_70px_-42px_rgba(15,23,42,0.38)]">
              <div class:list={["px-5 pb-5 pt-5", accentClass]}>
                <div class="rounded-[1.4rem] border border-white/55 bg-white/20 p-2 backdrop-blur-sm">
                  <img
                    src={member.data.avatar.src}
                    alt={member.data.avatar.alt}
                    class="aspect-[4/3] w-full rounded-[1rem] object-cover"
                    loading="lazy"
                  />
                </div>
              </div>

              <div class="bg-card px-6 pb-7 pt-2">
                <div class="inline-flex rounded-full border border-border bg-background px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-muted-foreground">
                  {getFirstName(member.data.name)}
                </div>
                <h3 class="mt-4 text-[1.9rem] font-semibold leading-tight tracking-tight text-card-foreground">
                  {member.data.name}
                </h3>
                <p class="mt-4 text-[1rem] leading-8 text-card-foreground/78">
                  {member.data.biography}
                </p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

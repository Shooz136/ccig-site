---
import { getCollection } from "astro:content";
import Container from "@/components/container.astro";
import { siteConfig } from "@/config/site";
import { normalizePageSlug } from "@/lib/pages";
import Dropdown from "./dropdown.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const navPages = await getCollection("pages", ({ data }) => {
  return !data.draft && data.showInNav;
});

const sortPages = (a, b) => {
  if (a.data.navOrder !== b.data.navOrder) {
    return a.data.navOrder - b.data.navOrder;
  }

  return a.data.title.localeCompare(b.data.title);
};

const childPagesByParent = new Map();

for (const page of navPages) {
  const normalizedSlug = normalizePageSlug(page.slug);

  if (!normalizedSlug.includes("/")) {
    continue;
  }

  const parentSlug = normalizedSlug.split("/").slice(0, -1).join("/");
  const siblings = childPagesByParent.get(parentSlug) || [];
  siblings.push({ ...page, normalizedSlug });
  childPagesByParent.set(parentSlug, siblings);
}

const menuitems = navPages
  .map((page) => ({ ...page, normalizedSlug: normalizePageSlug(page.slug) }))
  .filter((page) => page.normalizedSlug && !page.normalizedSlug.includes("/"))
  .sort(sortPages)
  .map((page) => {
    const childItems = (childPagesByParent.get(page.normalizedSlug) || [])
      .sort(sortPages)
      .map((childPage) => ({
        title: childPage.data.navLabel || childPage.data.title,
        path: `/${childPage.normalizedSlug}`,
      }));

    if (childItems.length > 0) {
      return {
        title: page.data.navLabel || page.data.title,
        path: `/${page.normalizedSlug}`,
        children: [{ title: "Overview", path: `/${page.normalizedSlug}` }, ...childItems],
      };
    }

    return {
      title: page.data.navLabel || page.data.title,
      path: `/${page.normalizedSlug}`,
    };
  });
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="text-lg"
          ><span class="font-bold text-foreground">{siteConfig.displayName || siteConfig.name}</span>
        </a>
        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 text-foreground" />
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-3">
          {
            menuitems.map((item, index) => (
              <>
                {item.children && (
                  <Dropdown
                    title={item.title}
                    children={item.children}
                    lastItem={index === menuitems.length - 1}
                  />
                )}

                {!item.children && (
                  <li>
                    <a
                      href={item.path}
                      class="flex lg:px-3 py-2 items-center text-muted-foreground hover-text-foreground">
                      <span> {item.title}</span>
                      {item.badge && (
                        <span class="ml-1 px-2 py-0.5 text-[10px] animate-pulse font-semibold uppercase text-primary-foreground bg-primary rounded-full">
                          New
                        </span>
                      )}
                    </a>
                  </li>
                )}
              </>
            ))
          }
        </ul>
      </MenuItems>
    </Astronav>
  </header>
</Container>

---
import { siteConfig } from "@/config/site";

const footerContactCta = siteConfig.footerContactCta || {};
const eyebrow = footerContactCta.eyebrow || "";
const headline = footerContactCta.headline || "Contact us";
const body = footerContactCta.body || "";
const email = footerContactCta.email || "";
const buttonLabel = footerContactCta.buttonLabel || "Contact us";
const buttonHref = footerContactCta.buttonHref || (email ? `mailto:${email}` : "/contact");
---

<footer class="mt-20 border-t border-border/70 bg-[color:color-mix(in_srgb,var(--secondary)_62%,white)]">
  <div class="mx-auto max-w-6xl px-6 py-14 md:px-8 lg:px-10">
    <div class="overflow-hidden rounded-[2rem] border border-border/70 bg-background shadow-[0_30px_90px_-54px_rgba(12,40,99,0.4)]">
      <div class="grid gap-8 px-8 py-10 md:grid-cols-[minmax(0,1fr)_auto] md:items-end md:px-12 md:py-12">
        <div class="max-w-3xl">
          {
            eyebrow && (
              <p class="text-xs font-semibold uppercase tracking-[0.28em] text-primary">
                {eyebrow}
              </p>
            )
          }
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
            {headline}
          </h2>
          {
            body && (
              <p class="mt-4 max-w-2xl text-base leading-8 text-muted-foreground sm:text-lg">
                {body}
              </p>
            )
          }
          {
            email && (
              <a
                href={`mailto:${email}`}
                class="mt-5 inline-flex text-sm font-medium text-primary transition hover:text-[color:color-mix(in_srgb,var(--primary)_82%,black)]"
              >
                {email}
              </a>
            )
          }
        </div>

        <div class="md:self-center">
          <a
            href={buttonHref}
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-primary px-6 py-3 text-base font-semibold text-primary-foreground transition hover:translate-y-[-1px] hover:bg-[color:color-mix(in_srgb,var(--primary)_90%,black)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
          >
            {buttonLabel}
          </a>
        </div>
      </div>
    </div>

    <p class="mt-8 text-center text-sm text-muted-foreground">
      Copyright © {new Date().getFullYear()} {siteConfig.displayName || siteConfig.name}. All rights reserved.
    </p>
  </div>
</footer>

---
import Link from "@/components/ui/link.astro";

const { sponsor } = Astro.props;
---

<article class="flex h-full flex-col rounded-3xl border border-border bg-background p-6 shadow-[0_20px_50px_-35px_rgba(15,23,42,0.35)]">
  <img
    src={sponsor.data.image.src}
    alt={sponsor.data.image.alt}
    class="h-44 w-full rounded-2xl border border-border object-cover"
    loading="lazy"
  />
  <div class="mt-5">
    <h3 class="mt-3 text-2xl font-semibold leading-tight text-foreground">
      {sponsor.data.name}
    </h3>
  </div>
  <p class="mt-4 leading-relaxed text-foreground/78">
    {sponsor.data.description}
  </p>
  {
    sponsor.data.website && (
      <div class="mt-6">
        <Link href={sponsor.data.website} style="primary" size="md">
          Visit Sponsor
        </Link>
      </div>
    )
  }
</article>
